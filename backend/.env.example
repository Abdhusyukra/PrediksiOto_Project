# Salin isi file ini ke Railway Environment Variables
# Jangan commit file .env asli ke GitHub!

DB_HOST=         # Dari Railway MySQL: MYSQLHOST
DB_PORT=         # Dari Railway MySQL: MYSQLPORT (biasanya 3306)
DB_NAME=         # Dari Railway MySQL: MYSQLDATABASE
DB_USER=         # Dari Railway MySQL: MYSQLUSER
DB_PASSWORD=     # Dari Railway MySQL: MYSQLPASSWORD
JWT_SECRET_KEY=  # Ganti dengan string acak panjang (min 32 karakter)
FLASK_ENV=production
